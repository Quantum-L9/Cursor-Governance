# Copy to ~/.cursor/graphiti.env — NEVER commit secrets
GRAPHITI_MEMORY_ENABLED=1
GRAPHITI_WRITE_GATES=0
# Mac: SSH tunnel first — ssh -N -L 8100:127.0.0.1:8100 -i ~/.ssh/Hetzner-C1-nopass root@46.62.243.82
# Always-on tunnel: set GRAPHITI_TUNNEL_AUTOSTART=1 and the SSH_* vars below; setup_workspace_symlinks.sh
# installs a launchd LaunchAgent (com.cursor.graphiti-tunnel) that survives reboot and auto-restarts.
GRAPHITI_TUNNEL_AUTOSTART=0
GRAPHITI_SSH_HOST=46.62.243.82
GRAPHITI_SSH_USER=root
GRAPHITI_SSH_KEY=$HOME/.ssh/Hetzner-C1-nopass
GRAPHITI_TUNNEL_LOCAL_PORT=8100
GRAPHITI_TUNNEL_REMOTE_PORT=8100
GRAPHITI_MCP_URL=http://127.0.0.1:8100/mcp/
GRAPHITI_MCP_TOKEN=
GRAPHITI_NEO4J_URI=bolt://100.x.x.x:7687
NEO4J_PASSWORD=
OPENAI_API_KEY=
MEMORY_TOKEN_BUDGET=400
MEMORY_RATE_LIMIT_MIN=10
MEMORY_RATE_LIMIT_HR=200
MEMORY_DISTILL_TOKEN_BUDGET=300
GRAPHITI_TELEMETRY_ENABLED=false
