# ═══════════════════════════════════════════════════════════════════════════════
# GRAPHITI ENV — MACHINE-LEVEL ONLY (NOT PER REPO)
# ═══════════════════════════════════════════════════════════════════════════════
#
# DO NOT copy this file into a cloned repo. Clones work without repo-local graphiti env.
#
# Architecture:
#   • Safe defaults     → graphiti.env.defaults (in GlobalCommands, auto-loaded)
#   • Machine overrides → ~/.cursor/graphiti.env (once per Mac)
#   • Secrets overlay   → ~/.cursor/secrets/graphiti.env OR macOS Keychain
#   • Repo clone        → needs NOTHING except symlinks + optional .env.local C1_SSH
#
# One-time setup (any machine):
#   bash "$HOME/Dropbox/Cursor Governance/GlobalCommands/ops/scripts/init_graphiti_machine_env.sh"
#
# See: ops/graphiti/docs/MACHINE-ENV-POLICY.md
# ═══════════════════════════════════════════════════════════════════════════════

# --- Safe defaults (also in graphiti.env.defaults — loaded automatically) ---
GRAPHITI_MEMORY_ENABLED=1
GRAPHITI_WRITE_GATES=0
GRAPHITI_TUNNEL_AUTOSTART=1
GRAPHITI_SSH_HOST=46.62.243.82
GRAPHITI_SSH_USER=root
GRAPHITI_SSH_KEY=$HOME/.ssh/Hetzner-C1-nopass
GRAPHITI_TUNNEL_LOCAL_PORT=8100
GRAPHITI_TUNNEL_REMOTE_PORT=8100
GRAPHITI_MCP_URL=http://127.0.0.1:8100/mcp/

# --- Secrets (machine only — use ONE of these methods) ---
# Method A (recommended): macOS Keychain
#   security add-generic-password -a "$USER" -s graphiti-mcp-token -w "YOUR_VPS_TOKEN"
# Method B: secrets overlay file (never commit)
#   cp ~/.cursor/secrets/graphiti.env.example ~/.cursor/secrets/graphiti.env
GRAPHITI_MCP_TOKEN=

# --- VPS-only (do NOT put on Mac ~/.cursor/graphiti.env) ---
# OPENAI_API_KEY=        # VPS /opt/graphiti-cursor/graphiti.env only
# NEO4J_PASSWORD=        # VPS only

MEMORY_TOKEN_BUDGET=400
MEMORY_RATE_LIMIT_MIN=10
MEMORY_RATE_LIMIT_HR=200
MEMORY_DISTILL_TOKEN_BUDGET=300
GRAPHITI_TELEMETRY_ENABLED=false
