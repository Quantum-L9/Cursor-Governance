# Machine-level safe defaults — NO SECRETS. Sourced before ~/.cursor/graphiti.env.
# Repo clones do NOT need a copy of this file; hooks/CLI load these automatically.

GRAPHITI_MEMORY_ENABLED="${GRAPHITI_MEMORY_ENABLED:-1}"
GRAPHITI_WRITE_GATES="${GRAPHITI_WRITE_GATES:-0}"
GRAPHITI_MCP_URL="${GRAPHITI_MCP_URL:-http://127.0.0.1:8100/mcp/}"
GRAPHITI_SSH_HOST="${GRAPHITI_SSH_HOST:-46.62.243.82}"
GRAPHITI_SSH_USER="${GRAPHITI_SSH_USER:-root}"
GRAPHITI_SSH_KEY="${GRAPHITI_SSH_KEY:-$HOME/.ssh/Hetzner-C1-nopass}"
GRAPHITI_SSH_KEYCHAIN_SERVICE="${GRAPHITI_SSH_KEYCHAIN_SERVICE:-graphiti-c1-ssh-key}"
GRAPHITI_TUNNEL_LOCAL_PORT="${GRAPHITI_TUNNEL_LOCAL_PORT:-8100}"
GRAPHITI_TUNNEL_REMOTE_PORT="${GRAPHITI_TUNNEL_REMOTE_PORT:-8100}"
GRAPHITI_TUNNEL_AUTOSTART="${GRAPHITI_TUNNEL_AUTOSTART:-1}"
MEMORY_TOKEN_BUDGET="${MEMORY_TOKEN_BUDGET:-400}"
MEMORY_RATE_LIMIT_MIN="${MEMORY_RATE_LIMIT_MIN:-10}"
MEMORY_RATE_LIMIT_HR="${MEMORY_RATE_LIMIT_HR:-200}"
GRAPHITI_TELEMETRY_ENABLED="${GRAPHITI_TELEMETRY_ENABLED:-false}"
