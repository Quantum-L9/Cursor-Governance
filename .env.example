# ═══════════════════════════════════════════════════════════════════════════
# Cursor-Governance — repo-level environment flags
# ═══════════════════════════════════════════════════════════════════════════
#
# This file documents ONLY the behavior flags this repo's own scripts read
# directly from the process environment (confirmed via grep against
# ops/scripts/*.sh — not aspirational). It intentionally does NOT include:
#
#   - Graphiti connection/secrets vars (GRAPHITI_SSH_HOST, GRAPHITI_MCP_TOKEN,
#     etc.) — those are machine-level, not repo-level. See
#     ops/graphiti/graphiti.env.example, which explicitly says not to copy it
#     into a cloned repo. Machine setup: ops/scripts/init_graphiti_machine_env.sh
#   - L9_ROOT / distiller vars used by ops/scripts/transcript_distiller.py —
#     those configure this repo's integration with an external L9 runtime
#     repo and belong in that repo's own .env, not here.
#
# None of the values below are secrets. Copy to .env and source it, or export
# directly -- no script in this repo currently auto-loads a root .env file.

# governance_sync.sh -- mirror origin/main exactly on next sync, discarding
# local divergence. Opt-in only; never set this as a persistent default.
GOVERNANCE_SYNC_HARD_RESET=0

# backup_to_github.sh -- skip the sessionEnd auto-backup for one session.
GOVERNANCE_BACKUP_SKIP=0

# backup_to_github.sh -- show what would be committed/pushed without doing it.
GOVERNANCE_BACKUP_DRY_RUN=0

# CANONICAL_LAW.md section 10 -- locks the production environment. Default
# false; do not flip in this repo without reading that section first.
GOVERNANCE_HARDENING_ENABLED=false

# CANONICAL_LAW.md section 10 / 8 -- Graphiti memory layer master switches.
# These two ARE read by this repo's own scripts (not just the Graphiti
# subsystem), which is why they're listed here rather than deferred to
# graphiti.env.example.
GRAPHITI_MEMORY_ENABLED=true
GRAPHITI_WRITE_GATES=true
